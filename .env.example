NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://daemon:daemon@localhost:5432/daemon
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222
COLLECT_SENSING_URL=http://localhost:8081
DAEMON_INGEST_URL=http://127.0.0.1:8081
# Set to 1 for local dev without the Go ingest service (registers entities in-memory only).
DAEMON_INGEST_SKIP_UPSTREAM=1
# HTTP policy adapter (gateway POST /check). Run: cargo run -p daemon-policy --bin policy-http-server
POLICY_ENGINE_URL=http://localhost:8082
# Legacy TCP policy-server uses the same port but a line protocol — do not point POLICY_ENGINE_URL at it.
# Set to 1 when the Rust/Go policy service is not running (uses in-gateway Authorizer in dev).
DAEMON_POLICY_SKIP_UPSTREAM=1
# ABC Express shadow parity fixtures (enables abc-fixture-* ingest sources in CI/local).
# DAEMON_ABC_FIXTURES=1
# Live Antero shadow read (read-only Supabase session pooler URL — never commit):
# ANTERO_SUPABASE_DB_URL=postgresql://...
# DAEMON_ABC_LIVE_INGEST=1
# ClickHouse OLAP for read-only shadow pricing (optional; ontology fallback when unset).
# DAEMON_CLICKHOUSE_URL=http://127.0.0.1:8124
# DAEMON_CLICKHOUSE_DATABASE=abc_express
# Opt-in legacy allow-all dev policy (default is RBAC via configs/governance/rbac.yaml).
# DAEMON_POLICY_DEV_ALLOW=1
DAEMON_CONFIG_DIR=./configs
DAEMON_REPO_ROOT=.

# Auth: dev mode uses DAEMON_API_KEY when DAEMON_API_KEYS is unset (local gateway only).
# Production requires explicit DAEMON_API_KEYS — never ship without configured keys.
DAEMON_AUTH_MODE=dev
DAEMON_API_KEY=daemon-dev-key
# Format: key:subjectId:tenantId:role1,role2
# Staging ABC / ANTERO (see deployment/staging/abc-antero.env.example):
# DAEMON_API_KEYS=<viewer-key>:antero-bff:abc-antero:logistics-viewer,<analyst-key>:antero-aip:abc-antero:commercial-analyst
# DAEMON_API_KEYS=prod-key-1:svc:inst-alpha:admin

# Integration tests (optional; defaults to DAEMON_API_KEY)
# DAEMON_TEST_DEFAULT_API_KEY=daemon-dev-key

# dsdk-console local dev (Vite)
# VITE_DAEMON_API_KEY=daemon-dev-key

# OpenRouter / agent-grade LLM (optional; deterministic fallbacks without key)
# OPENROUTER_API_KEY=
# DAEMON_OPENROUTER_API_KEY=
# DAEMON_ONTOLOGY_QUERY_ENABLED=1
# DAEMON_ONTOLOGY_QUERY_MODEL=anthropic/claude-sonnet-4.5
# DAEMON_OPENROUTER_DATA_COLLECTION=deny
# DAEMON_OPENROUTER_PROVIDER_ORDER=
# DAEMON_OPENROUTER_MODELS=
# DAEMON_OPENROUTER_ROUTE=fallback
# DAEMON_OPENROUTER_SITE_URL=
# DAEMON_OPENROUTER_SITE_NAME=daemon-sdk
# DAEMON_AGENT_MAX_STEPS=8

# OIDC JWT verification (production). When set, Bearer tokens are verified via JWKS.
# DAEMON_OIDC_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# DAEMON_OIDC_ISSUER=https://issuer.example.com/
# DAEMON_OIDC_AUDIENCE=daemon-gateway

# Webhook HMAC (required in production policy mode or when DAEMON_WEBHOOK_REQUIRE_HMAC=1).
# DAEMON_WEBHOOK_HMAC_SECRET=change-me
# DAEMON_WEBHOOK_REQUIRE_HMAC=1
