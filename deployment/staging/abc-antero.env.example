# ABC Express / ANTERO staging profile (copy to host env or Railway variables).
# See docs/integrations/antero-platform-fase-a.md and docs/20-deployment-go-live-guide.md

NODE_ENV=production
PORT=3000
DAEMON_REPO_ROOT=/app
DAEMON_CONFIG_DIR=/app/configs
DAEMON_AUTH_MODE=prod
DAEMON_POSTGRES_URL=postgresql://daemon:CHANGE_ME@postgres:5432/daemon

# Two keys for BFF RBAC split (viewer vs analyst). Format: key:subjectId:tenantId:role1,role2
# Generate with: openssl rand -hex 32
DAEMON_API_KEYS=CHANGE_VIEWER_KEY:antero-bff:abc-antero:logistics-viewer,CHANGE_ANALYST_KEY:antero-aip:abc-antero:commercial-analyst

# Policy: use Rust policy-http-server in staging, or temporary skip during bootstrap only
POLICY_ENGINE_URL=http://policy:8082
# DAEMON_POLICY_SKIP_UPSTREAM=1

# ABC fixture ingest sources (run scripts/bootstrap-abc-staging.mjs after gateway is up)
DAEMON_ABC_FIXTURES=1

# NL query / AIP (optional — queryAsk returns structured error when graph off)
DAEMON_ONTOLOGY_QUERY_ENABLED=1
# DAEMON_NEO4J_URI=bolt://neo4j:7687
# DAEMON_NEO4J_USER=neo4j
# DAEMON_NEO4J_PASSWORD=CHANGE_ME
# OPENROUTER_API_KEY=
# DAEMON_ONTOLOGY_QUERY_MODEL=anthropic/claude-sonnet-4.5

# ClickHouse shadow pricing OLAP (optional; ontology-only fallback)
# DAEMON_CLICKHOUSE_URL=http://clickhouse:8124
# DAEMON_CLICKHOUSE_DATABASE=abc_express

# Consumer smoke (scripts/antero-consumer-smoke.mjs)
# DAEMON_GATEWAY_URL=https://staging-gateway.example.com
# DAEMON_STAGING_VIEWER_API_KEY=
# DAEMON_STAGING_ANALYST_API_KEY=
